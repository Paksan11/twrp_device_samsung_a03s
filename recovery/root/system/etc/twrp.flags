# mount point    	fs          type		device			device2				flags
system		/system     		ext4							logical,first_stage_mount,slotselect
vendor		/vendor      		ext4							logical,first_stage_mount,slotselect
product		/product        	ext4							logical,first_stage_mount,slotselect
odm  		/odm         		ext4							logical,first_stage_mount,slotselect

# Symlinked partitions

/boot    		emmc		/dev/block/platform/bootdevice/by-name/boot			flags=backup=1;flashimg
/recovery    	emmc		/dev/block/platform/bootdevice/by-name/recovery		flags=backup=1;flashimg
/dtbo_image 	emmc		/dev/block/platform/bootdevice/by-name/dtbo			flags=backup=1;flashimg=1;display="DTBO Image"
/md1img_image	emmc		/dev/block/platform/bootdevice/by-name/md1img		flags=backup=1;flashimg=1;display="MD1img Image"
/omr_image      emmc        /dev/block/platform/bootdevice/by-name/omr		    flags=backup=1;flashimg=1;display="OMR Image"
/optics_image	emmc		/dev/block/platform/bootdevice/by-name/optics   	flags=backup=1;flashimg=1;display="Optics Image"
/prism_image	emmc		/dev/block/platform/bootdevice/by-name/prism    	flags=backup=1;flashimg=1;display="Prism Image"
/product_image	emmc		/dev/block/mapper/product		flags=backup=1;flashimg=1;display="Product Image"
/system_image	emmc		/dev/block/mapper/system		flags=backup=1;flashimg=1;display="System Image"
/vendor_image	emmc		/dev/block/mapper/vendor		flags=backup=1;flashimg=1;display="Vendor Image"
/vbmeta_image	emmc		/dev/block/platform/bootdevice/by-name/vbmeta       flags=backup=1;flashimg=1;display="VBmeta Image"
/vbmeta_system_image	emmc		/dev/block/platform/bootdevice/by-name/vbmeta       flags=backup=1;flashimg=1;display="VBmeta_System Image"

# Physical partitions

/cache		ext4		/dev/block/platform/bootdevice/by-name/cache		flags=backup=1;display="Cache"
/data		f2fs    	 /dev/block/dm-45 	length=-16384
/efs		ext4		/dev/block/platform/bootdevice/by-name/sec_efs		flags=backup=1;display="EFS"
/metadata	ext4		/dev/block/platform/bootdevice/by-name/md_udc		flags=backup=1;display="Metadata"
/misc   	ext4		/dev/block/platform/bootdevice/by-name/misc  		flags=backup=1;display="Misc"
/nvram		emmc    	/dev/block/platform/bootdevice/by-name/nvram        flags=backup=1;display="NVram"
/nvdata		emmc    	/dev/block/platform/bootdevice/by-name/nvdata       flags=backup=1;display="NVdata"
/nvcfg		emmc    	/dev/block/platform/bootdevice/by-name/nvcfg        flags=backup=1;display="NVcfg"
/omr        ext4        /dev/block/platform/bootdevice/by-name/omr          flags=backup=1;display="OMR"
/optics     ext4		/dev/block/platform/bootdevice/by-name/optics   	flags=backup=1;display="Optics"
/prism      ext4		/dev/block/platform/bootdevice/by-name/prism     	flags=backup=1;display="Prism"
/persist	emmc    	/dev/block/platform/bootdevice/by-name/persist      flags=backup=1;display="Persist"
/spmfw		emmc		/dev/block/platform/bootdevice/by-name/spmfw		flags=backup=1;display="Spmfw"
/scp1		emmc		/dev/block/platform/bootdevice/by-name/scp1   		flags=backup=1;display="Scp1"
/sspm_1		emmc		/dev/block/platform/bootdevice/by-name/sspm_1		flags=backup=1;display="Sspm_1"

# SDCard & USB-OTG 

/external_sd	vfat	/dev/block/mmcblk1p1	/dev/block/mmcblk1		flags=display="Micro SD card";storage;wipeingui;removable
/usb-otg    	vfat	/dev/block/sda1 		/dev/block/sda			flags=display="USB-OTG";storage;wipeingui;removable
